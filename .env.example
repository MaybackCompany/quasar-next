# ─────────────────────────────────────────────────────────────
# Quasar Academy — environment
# Copy to .env.local and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Access mode: "public" (no gate, default) or "discord" (Discord role gate)
ACCESS_MODE=public

# Public base URL (used to build the OAuth redirect when behind a proxy).
# Optional locally; set in production e.g. https://academy.example.com
# BASE_URL=

# ── Required ONLY when ACCESS_MODE=discord ───────────────────
# iron-session cookie encryption key. MUST be >= 32 characters.
# Generate: openssl rand -base64 32
SESSION_SECRET=

# Discord application (https://discord.com/developers/applications)
# Add redirect URI in the app's OAuth2 settings: <BASE_URL>/auth/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Guild the membership/roles are checked against
DISCORD_GUILD_ID=

# Bot token — fallback role lookup when the OAuth guilds.members.read
# scope is unavailable. Bot must be in DISCORD_GUILD_ID.
DISCORD_BOT_TOKEN=

# Gate role IDs — at least ONE required. A user with any of these is authorized
# to read the paid lessons (the free/basic lessons stay public regardless).
ROLE_STUDENT=
ROLE_PRO=
ROLE_ELITE=
ROLE_STAFF=
