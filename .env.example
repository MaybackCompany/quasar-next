# ─────────────────────────────────────────────────────────────
# Quasar Academy — environment
# Copy to .env.local and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Access mode: "public" (no gate, default) or "discord" (Discord role gate)
ACCESS_MODE=public

# Public base URL (used to build the OAuth redirect when behind a proxy).
# Optional locally; set in production e.g. https://academy.example.com
# BASE_URL=

# ── Required ONLY when ACCESS_MODE=discord ───────────────────
# iron-session cookie encryption key. MUST be >= 32 characters.
# Generate: openssl rand -base64 32
SESSION_SECRET=

# Discord application (https://discord.com/developers/applications)
# Add redirect URI in the app's OAuth2 settings: <BASE_URL>/auth/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Guild the membership/roles are checked against
DISCORD_GUILD_ID=

# Bot token — used for the /admin grant/revoke, the role-lookup fallback, and
# pulling a member's role when their trial window ends. The bot must be in
# DISCORD_GUILD_ID with Manage Roles, sitting ABOVE the roles it manages.
DISCORD_BOT_TOKEN=

# Access + admin role IDs live in code (src/lib/auth/roles.ts), NOT in env.
# A user holding any grantsAccess role (e.g. FiveM Starterkit) is authorized;
# Director roles unlock /admin. So no ROLE_* env vars are needed.

# ── Time-limited trials (giveaways) ──────────────────────────
# Optional, but required to ENFORCE expiry. Without these the gate still works
# (role = access) and nobody is locked out, but no trial clock runs.
# Add a Vercel KV / Upstash store; it provides these two automatically:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Secret for the daily expiry cron (any long random string). The cron refuses
# to run without it. Vercel sends it as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# Default trial length applied on first authorized visit, in days. Defaults to 7.
# TRIAL_DEFAULT_DAYS=7
